<?xml version="1.0"?>
<sdf version="1.9">
  <model name="nexus_hexacopter">
    <pose>0 0 0.25 0 0 0</pose>

    <!-- ── Base link (central body) ─────────────────────────────────── -->
    <link name="base_link">
      <inertial>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.0625</ixx>
          <iyy>0.0625</iyy>
          <izz>0.1125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <!-- Central body (hexagonal approximation) -->
      <collision name="body_collision">
        <geometry>
          <cylinder><radius>0.15</radius><length>0.1</length></cylinder>
        </geometry>
      </collision>
      <visual name="body_visual">
        <geometry>
          <cylinder><radius>0.15</radius><length>0.1</length></cylinder>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.2 1</ambient>
          <diffuse>0.2 0.2 0.3 1</diffuse>
          <specular>0.15 0.15 0.15 1</specular>
        </material>
      </visual>

      <!-- 6 Arms at 60-degree intervals -->
      <visual name="arm_0">
        <pose>0.16 0 0 0 0 0</pose>
        <geometry><box><size>0.22 0.035 0.02</size></box></geometry>
        <material><ambient>0.5 0.1 0.1 1</ambient><diffuse>0.7 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="arm_1">
        <pose>0.08 0.1386 0 0 0 1.0472</pose>
        <geometry><box><size>0.22 0.035 0.02</size></box></geometry>
        <material><ambient>0.5 0.1 0.1 1</ambient><diffuse>0.7 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="arm_2">
        <pose>-0.08 0.1386 0 0 0 2.0944</pose>
        <geometry><box><size>0.22 0.035 0.02</size></box></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="arm_3">
        <pose>-0.16 0 0 0 0 3.1416</pose>
        <geometry><box><size>0.22 0.035 0.02</size></box></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="arm_4">
        <pose>-0.08 -0.1386 0 0 0 -2.0944</pose>
        <geometry><box><size>0.22 0.035 0.02</size></box></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="arm_5">
        <pose>0.08 -0.1386 0 0 0 -1.0472</pose>
        <geometry><box><size>0.22 0.035 0.02</size></box></geometry>
        <material><ambient>0.5 0.1 0.1 1</ambient><diffuse>0.7 0.15 0.15 1</diffuse></material>
      </visual>

      <!-- Landing gear -->
      <visual name="leg_1">
        <pose>0.12 0 -0.1 0 0 0</pose>
        <geometry><cylinder><radius>0.006</radius><length>0.15</length></cylinder></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>
      <visual name="leg_2">
        <pose>-0.06 0.104 -0.1 0 0 0</pose>
        <geometry><cylinder><radius>0.006</radius><length>0.15</length></cylinder></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>
      <visual name="leg_3">
        <pose>-0.06 -0.104 -0.1 0 0 0</pose>
        <geometry><cylinder><radius>0.006</radius><length>0.15</length></cylinder></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>

      <!-- ── IMU sensor ──────────────────────────────────────────────── -->
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>250</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.004</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.004</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.004</stddev></noise></z>
          </linear_acceleration>
        </imu>
        <topic>imu</topic>
      </sensor>

      <!-- ── GPS ─────────────────────────────────────────────────────── -->
      <sensor name="navsat_sensor" type="navsat">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <navsat>
          <position_sensing>
            <horizontal><noise type="gaussian"><mean>0.0</mean><stddev>0.5</stddev></noise></horizontal>
            <vertical><noise type="gaussian"><mean>0.0</mean><stddev>1.0</stddev></noise></vertical>
          </position_sensing>
        </navsat>
        <topic>navsat</topic>
      </sensor>

      <!-- ── Barometer ───────────────────────────────────────────────── -->
      <sensor name="air_pressure_sensor" type="air_pressure">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <reference_altitude>0</reference_altitude>
          <pressure><noise type="gaussian"><mean>0.0</mean><stddev>5.0</stddev></noise></pressure>
        </air_pressure>
        <topic>air_pressure</topic>
      </sensor>

      <!-- ── Magnetometer ────────────────────────────────────────────── -->
      <sensor name="magnetometer_sensor" type="magnetometer">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <magnetometer>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise></z>
        </magnetometer>
        <topic>magnetometer</topic>
      </sensor>

      <!-- ── Front camera ────────────────────────────────────────────── -->
      <sensor name="camera_front" type="camera">
        <pose>0.15 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.5708</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>0.1</near><far>100</far></clip>
        </camera>
        <topic>camera</topic>
      </sensor>

      <!-- ── Downward depth camera ───────────────────────────────────── -->
      <sensor name="depth_camera_down" type="depth_camera">
        <pose>0 0 -0.06 0 1.5708 0</pose>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image>
            <width>320</width>
            <height>240</height>
            <format>R_FLOAT32</format>
          </image>
          <clip><near>0.2</near><far>20</far></clip>
        </camera>
        <topic>depth_camera</topic>
      </sensor>

      <!-- ── 360 LiDAR ───────────────────────────────────────────────── -->
      <sensor name="lidar_sensor" type="gpu_lidar">
        <pose>0 0 0.06 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-0.2618</min_angle>
              <max_angle>0.2618</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>50.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>0.02</stddev>
          </noise>
        </lidar>
        <topic>lidar</topic>
      </sensor>

    </link>

    <!-- ── 6 Rotor links ─────────────────────────────────────────────── -->
    <!-- Rotor 0 (front, CW) -->
    <link name="rotor_0">
      <pose>0.27 0 0.03 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00003</ixx><iyy>0.00003</iyy><izz>0.00006</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.12</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.15 0.15 0.15 0.5</diffuse></material>
      </visual>
    </link>

    <!-- Rotor 1 (front-left, CCW) -->
    <link name="rotor_1">
      <pose>0.135 0.2338 0.03 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00003</ixx><iyy>0.00003</iyy><izz>0.00006</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.12</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.15 0.15 0.15 0.5</diffuse></material>
      </visual>
    </link>

    <!-- Rotor 2 (rear-left, CW) -->
    <link name="rotor_2">
      <pose>-0.135 0.2338 0.03 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00003</ixx><iyy>0.00003</iyy><izz>0.00006</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.12</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.15 0.15 0.15 0.5</diffuse></material>
      </visual>
    </link>

    <!-- Rotor 3 (rear, CCW) -->
    <link name="rotor_3">
      <pose>-0.27 0 0.03 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00003</ixx><iyy>0.00003</iyy><izz>0.00006</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.12</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.15 0.15 0.15 0.5</diffuse></material>
      </visual>
    </link>

    <!-- Rotor 4 (rear-right, CW) -->
    <link name="rotor_4">
      <pose>-0.135 -0.2338 0.03 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00003</ixx><iyy>0.00003</iyy><izz>0.00006</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.12</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.15 0.15 0.15 0.5</diffuse></material>
      </visual>
    </link>

    <!-- Rotor 5 (front-right, CCW) -->
    <link name="rotor_5">
      <pose>0.135 -0.2338 0.03 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00003</ixx><iyy>0.00003</iyy><izz>0.00006</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.12</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 0.5</ambient><diffuse>0.15 0.15 0.15 0.5</diffuse></material>
      </visual>
    </link>

    <!-- ── Rotor joints ──────────────────────────────────────────────── -->
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent><child>rotor_0</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent><child>rotor_1</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent><child>rotor_2</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent><child>rotor_3</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="rotor_4_joint" type="revolute">
      <parent>base_link</parent><child>rotor_4</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>
    <joint name="rotor_5_joint" type="revolute">
      <parent>base_link</parent><child>rotor_5</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

  </model>
</sdf>
