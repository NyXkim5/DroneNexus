<?xml version="1.0"?>
<model>
  <name>NEXUS Hexacopter</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <author>
    <name>NEXUS Dev Team</name>
    <email>dev@nexus.local</email>
