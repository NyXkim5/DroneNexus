@-webkit-keyframes drag {
	0% { -webkit-transform: translate(0) ; }
	
	50% { -webkit-transform: translate(100px) }
	
	100% { -webkit-transform: translate(0); }
	
	50% { -webkit-transform: translate(-100px) }
	
	0% { -webkit-transform: translate(0) ; }
}
@keyframes drag {
	0% { transform: translate(0); }
	
	50% { transform: translate(100px); }
	
	100% { transform: translate(0); }
	
	50% { transform: translate(-100px); }
	
	0% { transform: translate(0); }
}

